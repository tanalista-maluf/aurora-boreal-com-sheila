{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/inscricao/",
      "destination": "https://forms.gle/msm8FLbKhzcX1Pb3A",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    }
  ]
}
